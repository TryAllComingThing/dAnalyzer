#!/usr/bin/env bash
# SessionStart hook for dAnalyzer plugin
# 只注入路由规则（轻量级 ~500B），角色和灵魂通过 CLAUDE.md 按需引用
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# 只加载路由规则
routing_content=$(cat "${PLUGIN_ROOT}/agents/use-danalyzer.md" 2>&1 || echo "")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

routing_escaped=$(escape_for_json "$routing_content")

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$routing_escaped"

exit 0

#!/usr/bin/env bash
# SessionStart hook for dAnalyzer plugin
# 注入精简路由规则 + 学习系统本能索引
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# 加载精简路由规则（来自 hooks/session-routing.md）
routing_content=$(cat "${PLUGIN_ROOT}/hooks/session-routing.md" 2>&1 || echo "")

# 加载学习系统本能索引（以纯文本形式获取，避免 JSON 嵌套）
learn_context=$(CLAUDE_PLUGIN_ROOT= "${PLUGIN_ROOT}/learn/hooks/load-instincts" 2>/dev/null || echo "")

# 合并上下文
combined_context=""
if [ -n "$routing_content" ]; then
    combined_context="${routing_content}"
fi
if [ -n "$learn_context" ]; then
    combined_context="${combined_context}"$'\n'"${learn_context}"
fi

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

context_escaped=$(escape_for_json "$combined_context")

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context_escaped"

exit 0

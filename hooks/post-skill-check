#!/usr/bin/env bash
# Post-skill-check hook for dAnalyzer
# Runs after Skill tool execution to check if security processing is needed
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Output skills that require mandatory security processing
OUTPUT_SKILLS="visual dashboard report"

# The skill name is passed as the first argument (for direct invocation)
# or detected from the tool context
SKILL_NAME="${1:-}"

# Check if the executed skill is an output skill
is_output_skill() {
    local skill="$1"
    for os in $OUTPUT_SKILLS; do
        if [[ "$skill" == *"$os"* ]]; then
            return 0
        fi
    done
    return 1
}

if [ -n "$SKILL_NAME" ] && is_output_skill "$SKILL_NAME"; then
    # This is an output skill — verify security was applied
    # The actual enforcement happens in danalyzer-core;
    # this hook provides the detection signal
    printf '{"hookSpecificOutput": {"hookEventName": "PostToolUse", "additionalContext": "SECURITY_REQUIRED: Output skill %s executed. Ensure security masking was applied before user delivery."}}\n' "$SKILL_NAME"
fi

exit 0

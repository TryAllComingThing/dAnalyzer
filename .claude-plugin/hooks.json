{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" session-start",
            "async": false
          }
        ],
        "description": "dAnalyzer: Inject routing rules"
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/learn/hooks/load-instincts\"",
            "async": false
          }
        ],
        "description": "dAnalyzer: Load instinct index (lightweight)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" post-skill-check",
            "async": false
          }
        ],
        "description": "dAnalyzer: Trigger security check after skill execution"
      },
      {
        "matcher": "Skill|Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/learn/hooks/analyze-observe\"",
            "async": false
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/learn/hooks/instinct-apply\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "dAnalyzer: Record observations and apply instincts on demand"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" session-end",
            "async": false
          }
        ],
        "description": "dAnalyzer: Session cleanup"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/learn/hooks/session-summary\"",
            "async": true,
            "timeout": 30
          }
        ],
        "description": "dAnalyzer: Session summary and pattern detection"
      }
    ]
  },
  "security_config": {
    "auto_security": true,
    "output_skills": ["visual", "dashboard", "report"],
    "scan_on_write": true,
    "block_on_violation": true
  },
  "security_rules": {
    "forbidden_patterns": [
      "\\d{17}[\\dXx]",
      "1[3-9]\\d{9}",
      "\\d{16,19}"
    ],
    "masking_rules": {
      "phone": "(\\d{3})\\d{4}(\\d{4})",
      "id_card": "(\\d{6})\\d{8}(\\d{4})",
      "bank_card": "\\d{4}\\s*\\d{4}\\s*\\d{4}\\s*\\d{4}"
    }
  },
  "learning_config": {
    "enabled": true,
    "description": "dAnalyzer Learning System Configuration"
  }
}

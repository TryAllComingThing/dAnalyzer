#!/usr/bin/env bash
# learn/hooks/session-summary
# Stop Hook - 会话结束时调用 Python session_processor 进行信号检测。
#
# 流程:
# 1. 加载 session observation JSONL
# 2. 运行 4 类信号检测器（correction / reinforcement / counterfactual / preference）
# 3. 写入信号 JSONL + 计数器
# 4. 输出学习摘要

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LEARN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SESSION_ID="${CLAUDE_SESSION_ID:-default}"
OBS_DIR="${LEARN_ROOT}/data/observations/sessions"
SIGNALS_DIR="${LEARN_ROOT}/data/signals"
COUNTERS_DIR="${LEARN_ROOT}/data/counters"

# ============================================
# 快速路径：无 observation 则跳过
# ============================================
obs_file="${OBS_DIR}/${SESSION_ID}.jsonl"
if [ ! -f "$obs_file" ] || [ ! -s "$obs_file" ]; then
    echo "#[dAnalyzer Learning] No observations recorded for session ${SESSION_ID}"
    exit 0
fi

obs_count=$(wc -l < "$obs_file" | tr -d ' ')
echo "#[dAnalyzer Learning] Session ${SESSION_ID}: ${obs_count} observations recorded"

# ============================================
# 调用 Python session_processor
# ============================================
python3 -c "
import json, sys
from pathlib import Path

sys.path.insert(0, '${LEARN_ROOT}/..')

from learn.ingest.session_processor import process_session, load_observations

observations = load_observations('${obs_file}')
if not observations:
    print('#[dAnalyzer Learning] No observations to process')
    sys.exit(0)

signals, counter = process_session(
    session_id='${SESSION_ID}',
    observations=observations,
    signals_dir='${SIGNALS_DIR}',
    counters_dir='${COUNTERS_DIR}',
)

# 输出摘要
by_type = {}
for s in signals:
    by_type[s.type.value] = by_type.get(s.type.value, 0) + 1

print(f'#[dAnalyzer Learning] Signals detected: {len(signals)} total')
for t, c in sorted(by_type.items()):
    print(f'#[dAnalyzer Learning]   {t}: {c}')
print(f'#[dAnalyzer Learning] Counter: queries={counter.total_queries} l1={counter.l1_hits} l2={counter.l2_hits} l3={counter.l3_fallbacks}')
" 2>&1

echo "#[dAnalyzer Learning] Session ${SESSION_ID} processing complete"

exit 0

#!/usr/bin/env bash
# learn/hooks/analyze-observe
# PostToolUse Hook - 记录分析行为到观察存储

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LEARN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# 环境变量由 Claude Code 提供
TOOL_NAME="${CLAUDE_TOOL_NAME:-}"
TOOL_INPUT="${CLAUDE_TOOL_INPUT:-}"
TOOL_RESULT="${CLAUDE_TOOL_RESULT:-}"
SESSION_ID="${CLAUDE_SESSION_ID:-default}"

# 观察存储目录
OBS_DIR="${LEARN_ROOT}/data/observations/sessions"
mkdir -p "$OBS_DIR"

# ============================================
# 观察类型判断
# ============================================

# 判断观察类型
get_observation_type() {
    local tool="$1"
    local input="$2"

    case "$tool" in
        Skill)
            # 解析 Skill 名称
            local skill_name=$(echo "$input" | grep -oP '(?<=Skill: )\w+' | head -1 || echo "unknown")

            # 根据 Skill 类型判断观察类型
            case "$skill_name" in
                data-query|query)
                    echo "query"
                    ;;
                data-analysis|analysis)
                    echo "analysis"
                    ;;
                visual|report)
                    echo "output"
                    ;;
                error-handler)
                    echo "error"
                    ;;
                *)
                    echo "general"
                    ;;
            esac
            ;;
        *)
            echo "general"
            ;;
    esac
}

# ============================================
# 数据提取
# ============================================

# 提取 Skill 名称
extract_skill_name() {
    local input="$1"
    echo "$input" | grep -oP '(?<=Skill: )\w+' | head -1 || echo "unknown"
}

# 提取自然语言查询
extract_nl_query() {
    local input="$1"
    # 提取 Skill: 后面的内容作为查询
    echo "$input" | sed 's/Skill: \w\+ *//' | head -c 500
}

# 提取生成的 SQL (如果有)
extract_generated_sql() {
    local result="$1"
    # 简单提取，假设 SQL 在结果中
    echo "$result" | grep -oP 'SELECT.*FROM.*' | head -1 | head -c 1000 || echo ""
}

# 提取分析指标
extract_indicators() {
    local input="$1"
    # 常见的指标关键词
    echo "$input" | grep -oiE '(销售|转化|增长|点击|访问|用户|订单|收入|成本|利润|毛利|客单)' | sort -u | tr '\n' ',' | sed 's/,$//'
}

# 提取分析维度
extract_dimensions() {
    local input="$1"
    # 常见的维度关键词
    echo "$input" | grep -oiE '(时间|区域|省份|城市|产品|类目|渠道|用户|性别|年龄|月份|日期)' | sort -u | tr '\n' ',' | sed 's/,$//'
}

# ============================================
# 记录观察
# ============================================

record_observation() {
    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local obs_type=$(get_observation_type "$TOOL_NAME" "$TOOL_INPUT")

    # 构建观察记录
    local obs_data=""

    case "$TOOL_NAME" in
        Skill)
            local skill_name=$(extract_skill_name "$TOOL_INPUT")
            local nl_query=$(extract_nl_query "$TOOL_INPUT")
            local indicators=$(extract_indicators "$TOOL_INPUT")
            local dimensions=$(extract_dimensions "$TOOL_INPUT")
            local generated_sql=$(extract_generated_sql "$TOOL_RESULT")

            obs_data=$(cat <<EOF
{"timestamp":"$timestamp","type":"$obs_type","session":"$SESSION_ID","tool":"$TOOL_NAME","skill":"$skill_name","nl_query":"$nl_query","indicators":"$indicators","dimensions":"$dimensions","sql":"$generated_sql"}
EOF
)
            ;;
        *)
            obs_data=$(cat <<EOF
{"timestamp":"$timestamp","type":"$obs_type","session":"$SESSION_ID","tool":"$TOOL_NAME"}
EOF
)
            ;;
    esac

    # 写入观察文件
    local obs_file="${OBS_DIR}/${SESSION_ID}.jsonl"
    echo "$obs_data" >> "$obs_file"
}

# ============================================
# 主逻辑
# ============================================

main() {
    # post-tool-use 已内置 Skill-only 守卫，至此仅处理 Skill 调用
    if [ "$TOOL_NAME" = "Skill" ]; then
        record_observation
    fi
}

main

exit 0

#!/usr/bin/env bash
# learn/hooks/analyze-observe
# PostToolUse Hook - 记录分析行为到观察存储 (v2 结构化)
#
# 产出 Observation v2 记录到 learn/data/observations/sessions/{session_id}.jsonl
# 相比 v1 增加了: candidates / context / user_anon_id / skill_chain / template

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LEARN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

TOOL_NAME="${CLAUDE_TOOL_NAME:-}"
TOOL_INPUT="${CLAUDE_TOOL_INPUT:-}"
SESSION_ID="${CLAUDE_SESSION_ID:-default}"

OBS_DIR="${LEARN_ROOT}/data/observations/sessions"
mkdir -p "$OBS_DIR"

# ============================================
# 辅助函数
# ============================================

get_turn_number() {
    local session_file="${OBS_DIR}/${SESSION_ID}.jsonl"
    if [ -f "$session_file" ]; then
        wc -l < "$session_file" 2>/dev/null || echo "0"
    else
        echo "0"
    fi
}

# 从 TOOL_INPUT 提取 skill 名称 (Skill: skill-name 格式)
extract_skill_name() {
    local input="$1"
    echo "$input" | grep -oP '(?<=Skill: )\w[\w-]*' | head -1 || echo "unknown"
}

# 提取自然语言查询（Skill: xxx 后面的内容）
extract_nl_query() {
    local input="$1"
    echo "$input" | sed 's/Skill: \w[\w-]* *//' | head -c 1000
}

# 哈希用户 ID（不可逆匿名化）
hash_user_id() {
    local raw="${CLAUDE_USER_ID:-anonymous}"
    echo "$raw" | shasum -a 256 | cut -c1-16
}

# 推断时间周期
infer_time_period() {
    local query="$1"
    local today
    today=$(date +%d)

    if echo "$query" | grep -qiE '(月底|月末|月末盘点|month.end)'; then
        echo "month_end"
    elif echo "$query" | grep -qiE '(季度|季度末|quarter.end)'; then
        echo "quarter_end"
    elif echo "$query" | grep -qiE '(促销|活动|大促|618|双11|双十二|promo)'; then
        echo "promo_period"
    else
        echo "normal"
    fi
}

# 推断触发来源
infer_trigger_source() {
    local input="$1"
    if echo "$input" | grep -qiE '(不对|不是|错了|纠正|修正|改成|换成)'; then
        echo "correction"
    elif echo "$input" | grep -qiE '(再来|接着|继续|还要|再给我)'; then
        echo "follow_up"
    else
        echo "new_query"
    fi
}

# 从 TOOL_RESULT 提取 candidates (如果工具输出包含候选信息)
extract_candidates() {
    local result="$1"
    local candidates_json="[]"

    # 尝试从 TOOL_RESULT 中提取 intent_parser 返回的 top-N 候选
    if echo "$result" | grep -q '"candidates"'; then
        candidates_json=$(echo "$result" | grep -oP '"candidates"\s*:\s*\[[^\]]+\]' | head -1 | sed 's/"candidates"\s*:\s*//' || echo "[]")
    fi
    echo "$candidates_json"
}

# ============================================
# 主逻辑
# ============================================

main() {
    # 仅处理 Skill 调用（PostToolUse hook 本身已限制）
    if [ "$TOOL_NAME" != "Skill" ]; then
        exit 0
    fi

    local skill_name
    skill_name=$(extract_skill_name "$TOOL_INPUT")
    local nl_query
    nl_query=$(extract_nl_query "$TOOL_INPUT")
    local user_anon_id
    user_anon_id=$(hash_user_id)
    local time_period
    time_period=$(infer_time_period "$nl_query")
    local trigger_source
    trigger_source=$(infer_trigger_source "$TOOL_INPUT")
    local turn
    turn=$(get_turn_number)
    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # 推断 industry（从 CLAUDE_PROJECT_DIR 或默认）
    local industry="general"
    if [ -n "${CLAUDE_PROJECT_DIR:-}" ]; then
        case "$CLAUDE_PROJECT_DIR" in
            *ecommerce*|*电商*) industry="ecommerce" ;;
            *finance*|*金融*)  industry="finance" ;;
            *logistics*|*物流*) industry="logistics" ;;
            *manufacturing*|*制造*) industry="manufacturing" ;;
        esac
    fi

    # 推断 source（L1 exact / L2 match / L3 fallback）
    local source="l2_match"
    if echo "$nl_query" | grep -qiE '(^$|unknown)'; then
        source="l3_fallback"
    fi

    # 构建 v2 observation JSON
    local obs_json
    obs_json=$(cat <<EOF
{
  "version": 2,
  "ts": "$timestamp",
  "session_id": "$SESSION_ID",
  "turn": $turn,
  "query": "$nl_query",
  "industry": "$industry",
  "source": "$source",
  "indicators_retrieved": [],
  "scenarios_retrieved": [],
  "models_retrieved": [],
  "analysis_type": "",
  "skill_chain_planned": [],
  "skill_chain_actual": [],
  "indicators_candidates": [],
  "template_matched": null,
  "context": {
    "time_period": "$time_period",
    "query_raw": "$nl_query",
    "trigger_source": "$trigger_source",
    "query_intent_hint": null
  },
  "user_anon_id": "$user_anon_id",
  "error": null
}
EOF
)

    # 写入 session observation 文件
    local obs_file="${OBS_DIR}/${SESSION_ID}.jsonl"
    echo "$obs_json" | tr -d '\n' >> "$obs_file"
    echo "" >> "$obs_file"

    # 额外记录 skill 调用计数
    local skill_log="${LEARN_ROOT}/data/observations/skill_calls/${SESSION_ID}.jsonl"
    mkdir -p "$(dirname "$skill_log")"
    echo "{\"ts\":\"$timestamp\",\"turn\":$turn,\"skill\":\"$skill_name\"}" >> "$skill_log"
}

main

exit 0
